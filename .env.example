# ── Pinecone ──────────────────────────────────────────────────────────────────
# Create a free account at https://pinecone.io → API Keys
PINECONE_API_KEY=

# Name of the index to create (e.g. mumzworld-gifts). Must exist before running catalog.py.
PINECONE_INDEX_NAME=mumzworld-gifts

# ── OpenRouter ────────────────────────────────────────────────────────────────
# Create a free account at https://openrouter.ai → Keys
# Used for Qwen2.5-72B-Instruct (intent extraction + gift ranking)
OPENROUTER_API_KEY=

# ── Groq Whisper (optional — for hosted STT) ──────────────────────────────────
# Create a free account at https://console.groq.com → API Keys
# Set USE_GROQ=true on deployed server for faster transcription
GROQ_API_KEY=
USE_GROQ=false

# ── Frontend (in frontend/.env.local) ─────────────────────────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:8000
# On Vercel/production: set to your deployed backend URL (e.g. https://mumzgift.onrender.com)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Optional ──────────────────────────────────────────────────────────────────
# URL of the deployed frontend (used in CORS allow-list)
FRONTEND_URL=http://localhost:3000
